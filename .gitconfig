  # This file was generated by generate_gitignore in ~/.dotfiles/scripts
  # Better edit that one!
  [user]
    name = x
    email = x
  [color]
    ui = auto
  [core]
    excludesfile = /Users/santiago/.gitignore
    editor = vim
  [apply]
    whitespace = nowarn
  [branch]
    autosetuprebase = always
  [grep]
    lineNumber = true
  [log]
    date = relative
    decorate = short
  [merge]
    ff = false
  [push]
    default = simple
  [github]
    user = o
  [credential]
    helper = osxkeychain
  [help]
    autocorrect = 1
