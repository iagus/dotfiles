{
    "editor.fontFamily": "Iosevka Type Slab",
    "editor.fontSize": 14,
    "editor.scrollBeyondLastLine": false,
    "explorer.openEditors.visible": 0,
    "terminal.external.osxExec": "iTerm.app",
    "terminal.integrated.fontFamily": "Mononoki",
    "editor.renderWhitespace": "all",
    "editor.selectionHighlight": false,

    // Files convention styleguide
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "files.encoding": "utf8",
    "files.trimTrailingWhitespace": true,
    "diffEditor.ignoreTrimWhitespace": true,
    "files.autoSave": "onFocusChange",
    "files.insertFinalNewline": true,

    // IntelliSense
    "editor.quickSuggestionsDelay": 5,
    "editor.acceptSuggestionOnEnter": false,
    "editor.wordBasedSuggestions": false,
    "javascript.suggest.alwaysAllWords": true,
    "javascript.suggest.useCodeSnippetsOnMethodSuggest": true,

    "files.exclude": {
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/.DS_Store": true,
        "**/tmp" : true,
        "**/node_modules": true,
        "**/.bundle": true
    },
    "files.watcherExclude": {
        "**/.git/objects/**": true,
        "**/node_modules/**": true,
        "**/bower_components/**": true,
        "**/.sass-cache/**": true
    },
    "search.exclude": {
        "**/tmp" : true,
        "**/node_modules": true,
        "**/bower_components": true,
        "**/.sass-cache": true,
        "**/public": true
    },
    "telemetry.enableTelemetry": false,
    "vsicons.hideFolders": true,

    // Git proyect
    "git.confirmSync": true,
    "gitProjectManager.baseProjectsFolders": ["/Users/santiago/code"],
    "gitProjectManager.ignoredFolders": [
        "node_modules",
        "bower_components",
        ".bundle",
        ".sass-cache",
        ".git"
    ],
    "gitProjectManager.maxDepthRecursion": 2,
    "gitProjectManager.openInNewWindow": false,
    "gitProjectManager.checkRemoteOrigin": false,
    "terminal.integrated.fontLigatures": true,
    "terminal.integrated.cursorBlinking": "phase",
    "window.zoomLevel": -1,

    "zenMode.hideStatusBar": true,
    "zenMode.hideTabs": true,
    "zenMode.fullScreen": true,

    // workbench colors
    "workbench.colorTheme": "Spacemacs - dark",
    "workbench.iconTheme": "seti",

    // other
    "editor.dragAndDrop": true,
    "editor.renderIndentGuides": false
}
